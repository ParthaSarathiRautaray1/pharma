// ═══════════════════════════════════════════════════════════════════
// PharmaCare ERP — Database Schema
//
// Conventions
//   • UUID primary keys everywhere.
//   • Money: Decimal(12,2). GST rates: Decimal(5,2).
//   • Every tenant-owned table carries pharmacyId; stock-bearing tables
//     also carry branchId (nullable until multi-branch is enabled).
//   • Stock truth lives on Batch.quantity; StockLedger is the immutable
//     movement journal that lets us audit/rebuild any balance.
//   • Monetary/tax fields on sale & purchase items are SNAPSHOTS taken
//     at transaction time — later price/GST edits never rewrite history.
// ═══════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  OWNER
  PHARMACIST
  CASHIER
  INVENTORY_MANAGER
}

enum PaymentMethod {
  CASH
  UPI
  CARD
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum SaleStatus {
  COMPLETED
  PARTIALLY_RETURNED
  RETURNED
}

enum PurchaseStatus {
  ORDERED
  RECEIVED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum StockMovementType {
  OPENING
  PURCHASE
  SALE
  SALE_RETURN
  ADJUSTMENT
}

enum AdjustmentReason {
  DAMAGE
  EXPIRY
  THEFT
  RECOUNT
  OTHER
}

enum NotificationType {
  LOW_STOCK
  NEAR_EXPIRY
  EXPIRED
  PENDING_PAYMENT
  INVOICE
  SYSTEM
  ERROR
}

enum SampleStatus {
  REGISTERED
  COLLECTED
  TESTING
  COMPLETED
  REPORT_READY
}

// ─── Tenant & Identity ───────────────────────────────────────────────

model Pharmacy {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  legalName      String?
  gstin          String?
  drugLicenseNo  String?
  phone          String
  email          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  pincode        String?
  logoUrl        String?
  invoicePrefix  String   @default("INV")
  // Free-form tenant settings: near-expiry window days, receipt footer,
  // loyalty earn rate, thermal paper width, etc.
  settings       Json     @default("{}")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branches      Branch[]
  users         User[]
  categories    Category[]
  brands        Brand[]
  medicines     Medicine[]
  suppliers     Supplier[]
  purchases     Purchase[]
  customers     Customer[]
  sales         Sale[]
  saleReturns   SaleReturn[]
  stockLedger   StockLedgerEntry[]
  adjustments   StockAdjustment[]
  patients      Patient[]
  samples       SampleCollection[]
  notifications Notification[]
  auditLogs     AuditLog[]
  counters      Counter[]
}

model Branch {
  id         String   @id @default(uuid()) @db.Uuid
  pharmacyId String   @db.Uuid
  name       String
  code       String
  phone      String?
  address    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  users    User[]

  @@unique([pharmacyId, code])
  @@index([pharmacyId])
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  // Null only for platform-level SUPER_ADMIN accounts
  pharmacyId   String?   @db.Uuid
  branchId     String?   @db.Uuid
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  pharmacy            Pharmacy?            @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  salesCreated        Sale[]               @relation("SaleCashier")
  purchasesCreated    Purchase[]
  returnsCreated      SaleReturn[]
  adjustmentsCreated  StockAdjustment[]
  paymentsReceived    Payment[]
  samplesCreated      SampleCollection[]
  notifications       Notification[]
  auditLogs           AuditLog[]

  @@index([pharmacyId])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  // Only a SHA-256 hash of the token is stored — a DB leak exposes nothing
  tokenHash String    @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Catalog & Inventory ────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  pharmacyId  String   @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pharmacy  Pharmacy   @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicines Medicine[]

  @@unique([pharmacyId, name])
}

model Brand {
  id           String   @id @default(uuid()) @db.Uuid
  pharmacyId   String   @db.Uuid
  name         String
  manufacturer String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pharmacy  Pharmacy   @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicines Medicine[]

  @@unique([pharmacyId, name])
}

model Medicine {
  id                   String   @id @default(uuid()) @db.Uuid
  pharmacyId           String   @db.Uuid
  categoryId           String?  @db.Uuid
  brandId              String?  @db.Uuid
  name                 String
  genericName          String?
  // Sale unit: TABLET, STRIP, BOTTLE, TUBE, VIAL, ...
  unit                 String   @default("STRIP")
  packSize             String?
  hsnCode              String?
  gstRate              Decimal  @default(12) @db.Decimal(5, 2)
  barcode              String?
  rackNumber           String?
  minStockLevel        Int      @default(10)
  requiresPrescription Boolean  @default(false)
  description          String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  pharmacy      Pharmacy           @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  category      Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand         Brand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  batches       Batch[]
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  ledgerEntries StockLedgerEntry[]

  @@unique([pharmacyId, barcode])
  @@index([pharmacyId, name])
  @@index([pharmacyId, isActive])
}

// One physical lot of a medicine. Prices are batch-level because two
// lots of the same medicine routinely carry different MRP/cost.
model Batch {
  id            String   @id @default(uuid()) @db.Uuid
  medicineId    String   @db.Uuid
  branchId      String?  @db.Uuid
  batchNumber   String
  mfgDate       DateTime?
  expiryDate    DateTime
  purchasePrice Decimal  @db.Decimal(12, 2)
  sellingPrice  Decimal  @db.Decimal(12, 2)
  mrp           Decimal  @db.Decimal(12, 2)
  quantity      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  medicine      Medicine           @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  adjustments   StockAdjustment[]
  ledgerEntries StockLedgerEntry[]

  @@unique([medicineId, batchNumber, branchId])
  @@index([expiryDate])
  @@index([medicineId, expiryDate])
}

// Immutable journal of every stock movement. balanceAfter lets any
// batch's history be audited without replaying all rows.
model StockLedgerEntry {
  id             String            @id @default(uuid()) @db.Uuid
  pharmacyId     String            @db.Uuid
  medicineId     String            @db.Uuid
  batchId        String            @db.Uuid
  movementType   StockMovementType
  // Signed: +ve for inbound (purchase/return), -ve for outbound (sale)
  quantityChange Int
  balanceAfter   Int
  // Polymorphic pointer to the source document (sale, purchase, ...)
  refType        String?
  refId          String?           @db.Uuid
  note           String?
  createdAt      DateTime          @default(now())

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  batch    Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([pharmacyId, createdAt])
  @@index([medicineId, createdAt])
  @@index([batchId])
}

model StockAdjustment {
  id             String           @id @default(uuid()) @db.Uuid
  pharmacyId     String           @db.Uuid
  batchId        String           @db.Uuid
  adjustedById   String           @db.Uuid
  // Signed delta applied to Batch.quantity
  quantityChange Int
  reason         AdjustmentReason
  note           String?
  createdAt      DateTime         @default(now())

  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  batch      Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  adjustedBy User     @relation(fields: [adjustedById], references: [id])

  @@index([pharmacyId, createdAt])
}

// ─── Suppliers & Purchasing ─────────────────────────────────────────

model Supplier {
  id            String   @id @default(uuid()) @db.Uuid
  pharmacyId    String   @db.Uuid
  name          String
  contactPerson String?
  phone         String
  email         String?
  gstin         String?
  address       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pharmacy  Pharmacy   @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  purchases Purchase[]

  @@unique([pharmacyId, phone])
  @@index([pharmacyId, name])
}

model Purchase {
  id                String         @id @default(uuid()) @db.Uuid
  pharmacyId        String         @db.Uuid
  supplierId        String         @db.Uuid
  createdById       String         @db.Uuid
  // Our sequential number (PO-2026-00042); supplier's bill number kept separately
  purchaseNumber    String
  supplierInvoiceNo String?
  status            PurchaseStatus @default(ORDERED)
  orderDate         DateTime       @default(now())
  receivedDate      DateTime?
  subtotal          Decimal        @default(0) @db.Decimal(12, 2)
  discountAmount    Decimal        @default(0) @db.Decimal(12, 2)
  taxAmount         Decimal        @default(0) @db.Decimal(12, 2)
  grandTotal        Decimal        @default(0) @db.Decimal(12, 2)
  paidAmount        Decimal        @default(0) @db.Decimal(12, 2)
  paymentStatus     PaymentStatus  @default(UNPAID)
  invoiceFileUrl    String?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  pharmacy  Pharmacy       @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  supplier  Supplier       @relation(fields: [supplierId], references: [id])
  createdBy User           @relation(fields: [createdById], references: [id])
  items     PurchaseItem[]
  payments  Payment[]

  @@unique([pharmacyId, purchaseNumber])
  @@index([pharmacyId, orderDate])
  @@index([supplierId])
  @@index([pharmacyId, paymentStatus])
}

model PurchaseItem {
  id            String    @id @default(uuid()) @db.Uuid
  purchaseId    String    @db.Uuid
  medicineId    String    @db.Uuid
  // Batch is created when goods are RECEIVED; null while only ordered
  batchId       String?   @db.Uuid
  batchNumber   String
  mfgDate       DateTime?
  expiryDate    DateTime
  quantity      Int
  freeQuantity  Int       @default(0)
  purchasePrice Decimal   @db.Decimal(12, 2)
  sellingPrice  Decimal   @db.Decimal(12, 2)
  mrp           Decimal   @db.Decimal(12, 2)
  gstRate       Decimal   @db.Decimal(5, 2)
  taxAmount     Decimal   @default(0) @db.Decimal(12, 2)
  total         Decimal   @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id])
  batch    Batch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([medicineId])
}

// ─── Customers & Sales ──────────────────────────────────────────────

model Customer {
  id            String    @id @default(uuid()) @db.Uuid
  pharmacyId    String    @db.Uuid
  name          String
  phone         String
  email         String?
  gender        String?
  dateOfBirth   DateTime?
  address       String?
  loyaltyPoints Int       @default(0)
  notes         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  pharmacy      Pharmacy       @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  sales         Sale[]
  payments      Payment[]
  prescriptions Prescription[]

  @@unique([pharmacyId, phone])
  @@index([pharmacyId, name])
}

model Prescription {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @db.Uuid
  saleId     String?  @db.Uuid
  fileUrl    String
  note       String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sale     Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([customerId])
}

model Sale {
  id             String        @id @default(uuid()) @db.Uuid
  pharmacyId     String        @db.Uuid
  customerId     String?       @db.Uuid
  cashierId      String        @db.Uuid
  invoiceNumber  String
  saleDate       DateTime      @default(now())
  subtotal       Decimal       @db.Decimal(12, 2)
  discountType   DiscountType?
  discountValue  Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(12, 2)
  roundOff       Decimal       @default(0) @db.Decimal(12, 2)
  grandTotal     Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(UNPAID)
  status         SaleStatus    @default(COMPLETED)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  pharmacy      Pharmacy       @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cashier       User           @relation("SaleCashier", fields: [cashierId], references: [id])
  items         SaleItem[]
  payments      Payment[]
  returns       SaleReturn[]
  prescriptions Prescription[]

  @@unique([pharmacyId, invoiceNumber])
  @@index([pharmacyId, saleDate])
  @@index([pharmacyId, paymentStatus])
  @@index([customerId])
}

model SaleItem {
  id               String  @id @default(uuid()) @db.Uuid
  saleId           String  @db.Uuid
  medicineId       String  @db.Uuid
  batchId          String  @db.Uuid
  quantity         Int
  returnedQuantity Int     @default(0)
  // Snapshots at time of sale — profit = (unitPrice - costPrice) × qty
  unitPrice        Decimal @db.Decimal(12, 2)
  mrp              Decimal @db.Decimal(12, 2)
  costPrice        Decimal @db.Decimal(12, 2)
  gstRate          Decimal @db.Decimal(5, 2)
  discountAmount   Decimal @default(0) @db.Decimal(12, 2)
  taxAmount        Decimal @default(0) @db.Decimal(12, 2)
  total            Decimal @db.Decimal(12, 2)

  sale        Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  medicine    Medicine         @relation(fields: [medicineId], references: [id])
  batch       Batch            @relation(fields: [batchId], references: [id])
  returnItems SaleReturnItem[]

  @@index([saleId])
  @@index([medicineId])
}

model SaleReturn {
  id           String        @id @default(uuid()) @db.Uuid
  pharmacyId   String        @db.Uuid
  saleId       String        @db.Uuid
  createdById  String        @db.Uuid
  returnNumber String
  reason       String?
  refundAmount Decimal       @db.Decimal(12, 2)
  refundMethod PaymentMethod @default(CASH)
  createdAt    DateTime      @default(now())

  pharmacy  Pharmacy         @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  sale      Sale             @relation(fields: [saleId], references: [id])
  createdBy User             @relation(fields: [createdById], references: [id])
  items     SaleReturnItem[]

  @@unique([pharmacyId, returnNumber])
  @@index([saleId])
}

model SaleReturnItem {
  id           String  @id @default(uuid()) @db.Uuid
  saleReturnId String  @db.Uuid
  saleItemId   String  @db.Uuid
  quantity     Int
  amount       Decimal @db.Decimal(12, 2)

  saleReturn SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  saleItem   SaleItem   @relation(fields: [saleItemId], references: [id])

  @@index([saleReturnId])
}

// One row per tender. Split payment on a sale = multiple rows.
// Also records supplier payments (purchaseId) and customer dues (customerId).
model Payment {
  id           String        @id @default(uuid()) @db.Uuid
  saleId       String?       @db.Uuid
  purchaseId   String?       @db.Uuid
  customerId   String?       @db.Uuid
  receivedById String        @db.Uuid
  amount       Decimal       @db.Decimal(12, 2)
  method       PaymentMethod
  reference    String?
  receivedAt   DateTime      @default(now())

  sale       Sale?     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  purchase   Purchase? @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  receivedBy User      @relation(fields: [receivedById], references: [id])

  @@index([saleId])
  @@index([purchaseId])
  @@index([receivedAt])
}

// ─── Sample Collection (Lab) ────────────────────────────────────────

model Patient {
  id         String    @id @default(uuid()) @db.Uuid
  pharmacyId String    @db.Uuid
  name       String
  phone      String
  age        Int?
  gender     String?
  address    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  pharmacy Pharmacy           @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  samples  SampleCollection[]

  @@unique([pharmacyId, phone])
  @@index([pharmacyId, name])
}

model SampleCollection {
  id           String       @id @default(uuid()) @db.Uuid
  pharmacyId   String       @db.Uuid
  patientId    String       @db.Uuid
  createdById  String       @db.Uuid
  sampleNumber String
  testName     String
  barcode      String
  status       SampleStatus @default(REGISTERED)
  collectedAt  DateTime?
  completedAt  DateTime?
  reportUrl    String?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  pharmacy  Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  patient   Patient  @relation(fields: [patientId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])

  @@unique([pharmacyId, sampleNumber])
  @@index([pharmacyId, status])
}

// ─── Platform ────────────────────────────────────────────────────────

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  pharmacyId String           @db.Uuid
  // Null = visible to all users of the pharmacy
  userId     String?          @db.Uuid
  type       NotificationType
  title      String
  message    String
  entityType String?
  entityId   String?          @db.Uuid
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([pharmacyId, isRead, createdAt])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  pharmacyId String?  @db.Uuid
  userId     String?  @db.Uuid
  action     String // e.g. sale.create, medicine.update, auth.login
  entityType String
  entityId   String?  @db.Uuid
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now())

  pharmacy Pharmacy? @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([pharmacyId, createdAt])
  @@index([entityType, entityId])
}

// Row-locked sequences for gap-tolerant document numbering:
// key examples: "invoice:2026", "purchase:2026", "return:2026", "sample:2026"
model Counter {
  id         String @id @default(uuid()) @db.Uuid
  pharmacyId String @db.Uuid
  key        String
  value      Int    @default(0)

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([pharmacyId, key])
}
