# ─── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5173
API_URL=http://localhost:5000

# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:5173

# ─── Database (Supabase / Render / VPS — only this changes on migration)
# Supabase: DATABASE_URL = transaction pooler (port 6543, add ?pgbouncer=true)
#           DIRECT_URL   = session pooler (port 5432), used only for migrations
# Local/VPS: point both at the same Postgres server.
DATABASE_URL=postgresql://postgres:password@localhost:5432/pharmacare?schema=public
DIRECT_URL=postgresql://postgres:password@localhost:5432/pharmacare?schema=public

# ─── Auth ────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-64-random-chars
JWT_REFRESH_SECRET=change-me-different-64-random-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ─── Email (any SMTP: Gmail app password for demo, provider SMTP in prod)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=app-password
MAIL_FROM="PharmaCare <no-reply@pharmacare.app>"

# ─── File storage adapter: "local" (VPS) | "supabase" (free tier) ────
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=pharmacare

# ─── Rate limiting ───────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ─── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info
